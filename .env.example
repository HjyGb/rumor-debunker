# ===========================================
# 阿里百炼云 API 配置
# ===========================================
# 请将 your_api_key_here 替换为您在阿里百炼云平台获取的真实 API Key
# 获取方式：登录 https://dashscope.console.aliyun.com/ -> API-KEY Management
DASHSCOPE_API_KEY=sk-your_api_key_here

# 阿里百炼云 OpenAI 兼容模式 API 地址
# 使用此兼容模式可以无缝对接原本为 OpenAI API 设计的代码
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
